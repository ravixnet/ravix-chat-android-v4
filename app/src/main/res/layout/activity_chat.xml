<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ravix_background"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:background="@color/ravix_primary"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#DCD9FF" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="@color/ravix_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/ravix_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="7dp"
            android:paddingEnd="6dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/chatStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="در حال دریافت تاریخچه..."
                android:textColor="@color/ravix_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/closeConversationButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="بستن گفتگو"
                android:textColor="@color/ravix_danger"
                app:icon="@drawable/ic_close"
                app:iconTint="@color/ravix_danger" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messageList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="ifContentScrolls"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:id="@+id/messageEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:alpha="0.65"
                android:contentDescription="پیامی نیست"
                android:src="@drawable/ic_ravix_chat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="در حال دریافت پیام‌های قبلی..."
                android:textColor="@color/ravix_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/jumpToLatestButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:text="آخرین پیام"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:backgroundTint="@color/ravix_primary"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_down"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/typingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="28dp"
        android:paddingStart="18dp"
        android:paddingTop="4dp"
        android:paddingEnd="18dp"
        android:paddingBottom="4dp"
        android:textColor="@color/ravix_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/composerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ravix_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:boxBackgroundColor="@color/ravix_surface_variant"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusTopStart="18dp"
            app:boxStrokeColor="@color/ravix_primary"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical|start"
                android:hint="پیام خود را بنویسید..."
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="5"
                android:minHeight="52dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/ravix_text"
                android:textColorHint="@color/ravix_muted"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:contentDescription="ارسال پیام"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text=""
            app:backgroundTint="@color/ravix_primary"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>
</LinearLayout>
